        <mxCell id="ZiCqnf-EbVQmUfoMXRJx-14" value="Initial State" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
