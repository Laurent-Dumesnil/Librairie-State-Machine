        <mxCell id="1GLfdaThtfdqlqExpZcu-14" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Initial State" vertex="1">
